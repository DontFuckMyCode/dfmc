# DFMC API Key Configuration
# Copy this file to .env and fill in your keys.
# Keys can also be set as environment variables (those take precedence).
# The .env copy of this file is gitignored — your keys stay local.
# NEVER COMMIT .env — it contains secrets.

# Z.AI / GLM provider
ZAI_API_KEY=<your-zai-key>

# MiniMax provider
MINIMAX_API_KEY=<your-minimax-key>

# Alibaba / Qwen provider
ALIBABA_API_KEY=<your-alibaba-key>

# OpenAI provider
OPENAI_API_KEY=<your-openai-key>

# Anthropic provider
ANTHROPIC_API_KEY=<your-anthropic-key>

# Google AI provider
GOOGLE_AI_API_KEY=<your-google-key>

# DeepSeek provider
DEEPSEEK_API_KEY=<your-deepseek-key>

# Kimi / Moonshot provider (KIMI_API_KEY is canonical; only one is required)
KIMI_API_KEY=<your-kimi-key>
MOONSHOT_API_KEY=<your-moonshot-key>
