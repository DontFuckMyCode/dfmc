{
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "dfmt recall --format md \u003e .dfmt/last-recall.md 2\u003e/dev/null || true",
            "statusMessage": "Saving session snapshot for next session...",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": ""
      },
      {
        "hooks": [
          {
            "command": "dfmt recall --save --format md",
            "statusMessage": "Saving session snapshot for next session...",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "if [ -f .dfmt/last-recall.md ]; then echo '--- Previous session summary ---' \u0026\u0026 cat .dfmt/last-recall.md \u0026\u0026 echo '--- End of previous session ---'; fi",
            "statusMessage": "Loading previous session summary...",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": ""
      },
      {
        "hooks": [
          {
            "command": "if (Test-Path .dfmt/last-recall.md) { Write-Host '--- Previous session summary ---'; Get-Content .dfmt/last-recall.md; Write-Host '--- End of previous session ---' }",
            "statusMessage": "Loading previous session summary...",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "permissions": {
    "allow": [
      "mcp__dfmt__dfmt.read",
      "mcp__dfmt__dfmt.exec",
      "mcp__dfmt__dfmt.fetch",
      "mcp__dfmt__dfmt.remember",
      "mcp__dfmt__dfmt.search",
      "mcp__dfmt__dfmt.recall",
      "mcp__dfmt__dfmt.stats",
      "Bash(dfmt recall --format md *)",
      "mcp__dfmt__dfmt_exec",
      "mcp__dfmt__dfmt_read",
      "mcp__dfmt__dfmt_fetch",
      "mcp__dfmt__dfmt_remember",
      "mcp__dfmt__dfmt_search",
      "mcp__dfmt__dfmt_recall",
      "mcp__dfmt__dfmt_stats",
      "mcp__dfmt__dfmt_glob",
      "mcp__dfmt__dfmt_grep",
      "mcp__dfmt__dfmt_edit",
      "mcp__dfmt__dfmt_write",
      "Bash(git *)"
    ],
    "deny": [
      "WebFetch",
      "WebSearch"
    ]
  }
}
